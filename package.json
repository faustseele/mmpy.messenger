{
  "name": "mmpy.chat",
  "private": true,
  "version": "0.0.0",
  "engines": {
    "node": ">=12"
  },
  "scripts": {
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint ./src && tsc --noEmit && stylelint '**/*.css'",
    "start": "vite build && vite preview",
    "start:fresh": "rm -rf node_modules/.vite && vite build && vite preview"
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@typescript-eslint/parser": "^8.32.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.31.0",
    "globals": "^16.1.0",
    "handlebars": "^4.7.8",
    "happy-dom": "^20.6.1",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "prettier-eslint": "^16.4.2",
    "stylelint": "^16.19.1",
    "stylelint-selector-bem-pattern": "^4.0.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.0",
    "vite": "^6.2.6",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "jsdom": "^28.1.0"
  }
}
